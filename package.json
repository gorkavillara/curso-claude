{
  "name": "taskmaster-ts",
  "version": "1.0.0",
  "description": "TaskMaster-TS: full-stack task manager with Node/Express/SQLite backend and a lightweight TypeScript frontend.",
  "private": true,
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "esbuild frontend/src/main.ts --bundle --format=esm --tsconfig=frontend/tsconfig.json --outfile=dist/frontend/main.js && node -e \"const fs=require('fs');fs.mkdirSync('dist/frontend',{recursive:true});fs.copyFileSync('frontend/index.html','dist/frontend/index.html');fs.copyFileSync('frontend/src/styles.css','dist/frontend/styles.css')\"",
    "start": "node dist/backend/server.js",
    "dev": "ts-node-dev --respawn --transpile-only backend/src/server.ts",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit -p backend/tsconfig.json && tsc --noEmit -p frontend/tsconfig.json",
    "clean": "rimraf dist"
  },
  "keywords": [
    "typescript",
    "express",
    "sqlite",
    "claude-code",
    "course"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.4",
    "express": "^4.17.1",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.4",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.13",
    "@types/jest": "^28.1.0",
    "@types/node": "^18.0.0",
    "@types/supertest": "^2.0.12",
    "esbuild": "^0.18.0",
    "jest": "^28.1.3",
    "rimraf": "^3.0.2",
    "supertest": "^6.3.0",
    "ts-jest": "^28.0.0",
    "ts-node-dev": "^2.0.0",
    "tslint": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
